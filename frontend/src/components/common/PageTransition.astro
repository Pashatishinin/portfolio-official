<div
  id="page-transition-overlay"
  class="fixed inset-0 top-0 bg-main z-[10000] h-[200vh] w-screen translate-y-full pointer-events-none"
  style="will-change: transform;"
>
</div>

<script>
  import gsap from "gsap";

  const debugPreloader = () => {
    console.log("--- Preloader Check ---");

    const preloader = document.querySelector(".preloader");
    console.log("1. Preloader element found:", !!preloader);

    const navEntries = performance.getEntriesByType("navigation");
    const navType =
      navEntries.length > 0
        ? (navEntries[0] as PerformanceNavigationTiming).type
        : "unknown";
    console.log("2. Navigation type:", navType);

    const alreadyVisited = sessionStorage.getItem("alreadyVisited");
    console.log("3. Session storage 'alreadyVisited':", alreadyVisited);

    const isReload = navType === "reload";
    const isFirstLoad = !alreadyVisited;

    console.log(
      "4. Decision -> isFirstLoad:",
      isFirstLoad,
      "| isReload:",
      isReload,
    );

    if (isFirstLoad || isReload) {
      console.log("5. STARTING ANIMATION");

      // Твоя логика анимации
      const tl = gsap.timeline({
        onStart: () => console.log("6. GSAP Timeline Started"),
        onComplete: () => console.log("7. GSAP Timeline Finished"),
      });

      // ... (остальной код анимации)

      // В конце анимации или в onStart ставим флаг
      sessionStorage.setItem("alreadyVisited", "true");
    } else {
      console.log("5. SKIPPING ANIMATION (Already visited)");
      if (preloader) {
        (preloader as HTMLElement).style.display = "none";
      }
    }
  };

  // Важно: слушаем событие загрузки страницы Astro
  document.addEventListener("astro:page-load", () => {
    console.log("EVENT: astro:page-load triggered");
    debugPreloader();
  });
</script>
