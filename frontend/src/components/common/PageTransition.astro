<div
  id="page-transition-overlay"
  class="fixed inset-0 top-0 bg-main z-[10000] h-[200vh] w-screen translate-y-full pointer-events-none"
  style="will-change: transform;"
>
</div>

<script>
  import gsap from "gsap";

  const initPageTransitions = () => {
    const overlay = document.getElementById("page-transition-overlay");
    if (!overlay) return;

    gsap.set(overlay, { yPercent: 120, skewY: 0 });

    document.addEventListener(
      "astro:before-preparation",
      (ev) => {
        const originalLoader = ev.loader;

        ev.loader = async () => {
          await gsap.to(overlay, {
            yPercent: -130,
            skewY: -1,
            duration: 1.2,
            ease: "expo.out",
            delay: 0.1,
          });

          await originalLoader();
        };
      },
      { once: true },
    );

    document.addEventListener("astro:after-swap", () => {
      gsap.set(overlay, { yPercent: 120 });
    });
  };

  document.addEventListener("astro:page-load", initPageTransitions);
</script>
