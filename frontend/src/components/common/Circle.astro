<section class="w-full">
  <div class="circle">
    <div class="text-container">
      <p id="circular-text">
        Scroll Down to see more&nbsp;Scroll Down to see more&nbsp;
      </p>
    </div>
  </div>
</section>

<style>
  .circle {
    position: relative;
    width: 200px;
    height: 200px;
    border-radius: 50%;
    display: flex;
    justify-content: center;
    align-items: center;
    overflow: visible;
  }

  .text-container {
    position: absolute;
    width: 100%;
    height: 100%;
  }

  .text-container :global(span) {
    position: absolute;
    left: 50%;
    transform-origin: 0 100px;
    font-size: 1.2rem;
    font-weight: bold;
    font-family: monospace;
    text-transform: uppercase;
  }

  #circular-text {
    opacity: 0;
  }
</style>

<script>
  import { gsap } from "gsap";
  import { ScrollTrigger } from "gsap/ScrollTrigger";

  gsap.registerPlugin(ScrollTrigger);

  function initCircle() {
    const textElement = document.getElementById(
      "circular-text",
    ) as HTMLParagraphElement;
    const container = document.querySelector(".text-container");
    const hero = document.getElementById("hero");

    if (textElement && container && !textElement.dataset.processed) {
      const str = textElement.innerText;
      const step = 360 / str.length;

      const globalDelay = (window as any).HERO_DELAY || 0;
      const finalDelay = globalDelay + 0.2;

      textElement.innerHTML = str
        .split("")
        .map(
          (char, i) =>
            `<span class="char" style="transform: rotate(${i * step}deg)">${char === " " ? "&nbsp;" : char}</span>`,
        )
        .join("");

      textElement.style.opacity = "1";
      textElement.dataset.processed = "true";

      gsap.from(textElement.querySelectorAll(".char"), {
        scale: 0,
        rotation: "-=180",
        duration: 1.2,
        delay: finalDelay,
        ease: "back.out(1.5)",
      });
      const rotationLoop = gsap.to(container, {
        rotation: "-=360",
        duration: 10,
        repeat: -1,
        ease: "none",
      });

      ScrollTrigger.create({
        trigger: hero || "body",
        start: "top top",
        end: "max",
        onUpdate: (self) => {
          const velocity = self.getVelocity() * 0.005;

          gsap.to(rotationLoop, {
            timeScale: 1 + Math.abs(velocity),
            duration: 0.3,
            overwrite: "auto",
          });
        },
        onToggle: (self) => {
          if (!self.isActive) {
            gsap.to(rotationLoop, { timeScale: 1, duration: 1 });
          }
        },
      });

      ScrollTrigger.addEventListener("scrollEnd", () => {
        gsap.to(rotationLoop, { timeScale: 1, duration: 1 });
      });
    }
  }

  initCircle();
  document.addEventListener("astro:page-load", initCircle);
  document.addEventListener("astro:after-swap", initCircle);
</script>
