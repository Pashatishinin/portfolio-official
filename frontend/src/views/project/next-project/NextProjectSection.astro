---
import { TextEffectLine } from "../../../components";
import CtaButton from "../../../components/ui/buttons/CtaButton.astro";

const { link } = Astro.props;
---

<section
  class="h-screen w-full max-h-200 flex flex-col justify-center items-center relative gap-20"
>
  <div class="flex flex-col justify-center items-center">
    <h1
      class="font-accent text-center font-black -tracking-widest text-main text-[clamp(42px,6vw+1rem,100px)] leading-[75%]"
    >
      <TextEffectLine mixBlend align="left" blockColor="#242424"
        >Next</TextEffectLine
      >
    </h1>
    <h1
      class="text-center font-black -tracking-widest text-main text-[clamp(42px,6vw+1rem,100px)] leading-[75%]"
    >
      <TextEffectLine mixBlend align="left" blockColor="#242424"
        >Project</TextEffectLine
      >
    </h1>
  </div>

  <CtaButton text="View Project" link={link} />
</section>
