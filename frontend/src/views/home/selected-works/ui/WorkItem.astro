---
import { object } from "astro:schema";
import { TextEffectLine, CtaButton } from "../../../../components";
import { MuxPlayer } from "@mux/mux-player-astro";
import { Image } from "astro:assets";

interface Props {
  title: string;
  link: string;
  videoSrc?: string;
  imgSrc?: string;
  poster?: string;
}

const { title, link, videoSrc, imgSrc, poster } = Astro.props;

const userAgent = Astro.request.headers.get("user-agent") || "";
const isMobile = /Mobile|Android|iPhone|iPad/i.test(userAgent);
const customPoster: string = (poster || imgSrc || "").toString();
---

<section class="work-item">
  <div class="work-item-img">
    {
      /* Если это НЕ мобилка и есть видео — грузим плеер с кастомным постером */
      !isMobile && videoSrc ? (
        <MuxPlayer
          playbackId={videoSrc}
          metadata={{ video_title: title }}
          autoplay="muted"
          loop
          muted
          playsInline
          preload="metadata"
          poster={customPoster}
          class="media-content"
        />
      ) : (
        /* На мобилках (или если нет видео) — показываем только оптимизированную картинку */
        /* Astro автоматически сожмет её и переведет в WebP */
        <Image
          src={poster || imgSrc || "/placeholder.webp"}
          alt={title}
          width={1000}
          height={1000}
          class="media-content"
          loading="eager"
          fetchpriority="high"
        />
      )
    }
    <!-- {
      videoSrc ? (
        <video autoplay muted loop playsinline poster={poster}>
          <source src={videoSrc} type="video/mp4" />
        </video>
      ) : (
        <img src={imgSrc} alt={title} loading="lazy" />
      )
    } -->
  </div>

  <div class="work-item-content">
    <div class="work-item-name">
      <h1
        class="font-main uppercase text-center text-[2.5rem] md:text-[5rem] font-semibold leading-none text-white"
      >
        <TextEffectLine
          title
          align="center"
          blockColor="var(--color-secondary)"
        >
          {title}
        </TextEffectLine>
      </h1>
    </div>

    <div class="work-item-link">
      <CtaButton link={link} text="View Project" />
    </div>
  </div>
</section>

<style>
  .media-content {
    height: 100% !important;
    width: auto !important;
    min-width: 100%; /* Гарантирует, что если видео узкое, оно заполнит ширину */
    object-fit: cover; /* Оставляет пропорции, заполняя контейнер */
    display: block;
  }

  /* Специфично для Mux Player, чтобы убрать черные полосы внутри тега */
  mux-player {
    --controls: none;
    --media-object-fit: cover;
    --media-object-position: center;
    height: 100%;
    aspect-ratio: 16 / 9; /* Задай примерное соотношение, чтобы браузер зарезервировал место */
  }

  .work-item {
    position: relative;
    /* width: 100vw; */
    height: 100svh;
    overflow: hidden;
  }

  .work-item-img {
    position: absolute;
    width: 100%;
    height: 100%;
    display: flex;
    justify-content: center;
    clip-path: polygon(25% 25%, 75% 40%, 100% 100%, 0% 100%);
    will-change: clip-path;
  }

  video,
  img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .work-item-name {
    position: absolute;
    top: 60%;
    left: 50%;
    transform: translate(-50%, -50%);
    width: 100%;
    z-index: 1;
  }

  .work-item-link {
    position: absolute;
    text-align: center;
    top: 70%;
    left: 50%;
    transform: translate(-50%, -50%);
    z-index: 1;
  }
  .work-item-name h1 {
    color: #fff;
  }

  @media (max-width: 1000px) {
    h1,
    .work-item-name h1 {
      font-size: 2.5rem;
    }
  }
</style>
