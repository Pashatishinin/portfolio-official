---
import Layout from "../../layouts/Layout.astro";
import FooterSection from "../../views/footer/FooterSection.astro";
import HeaderSectionProject from "../../views/header/HeaderSectionProject.astro";
import {
  AboutProjectSection,
  HeroSection,
  NextProjectSection,
  ShortPreviewSection,
} from "../../views/project";
import mainImg from "../../assets/8enjamin/main.jpg";

import video1 from "../../assets/8enjamin/1.mp4";
import video2 from "../../assets/8enjamin/2.mp4";
import video3 from "../../assets/8enjamin/3.mp4";
import video4 from "../../assets/8enjamin/4.mp4";
import video5 from "../../assets/8enjamin/5.mp4";

const videos = [
  { src: video1, poster: "/1.jpg" },
  { src: video2, poster: "/1.jpg" },
  { src: video3, poster: "/1.jpg" },
  { src: video4, poster: "/1.jpg" },
  { src: video5, poster: "/1.jpg" },
];

const role = ["Design", "Frontend Development", "CMS Architecture"];
const tools = ["Next.js", "Tailwind CSS", "GSAP", "Figma", "CMS Sanity"];
---

<Layout>
  <HeaderSectionProject />
  <HeroSection text="8enjamin" img={mainImg} />
  <AboutProjectSection role={role} tools={tools} year="2025" />

  <ShortPreviewSection listVideo={videos} />
  <NextProjectSection link="/ahin-anburaja" />
  <FooterSection />
</Layout>
